{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/academy",
      "destination": "/ai-academy.html"
    },
    {
      "source": "/products",
      "destination": "/digital-products.html"
    },
    {
      "source": "/content",
      "destination": "/content-studio.html"
    },
    {
      "source": "/legacy",
      "destination": "/legacy-services.html"
    },
    {
      "source": "/business",
      "destination": "/business-hub.html"
    },
    {
      "source": "/publishers",
      "destination": "/publishers.html"
    },
    {
      "source": "/music",
      "destination": "/music.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    }
  ]
}